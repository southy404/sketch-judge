{
  "name": "sketch-judge-mobile-ollama-v2",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host 127.0.0.1\" \"tsx server/index.ts\"",
